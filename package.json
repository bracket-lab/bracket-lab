{
  "name": "bracket-lab",
  "private": true,
  "scripts": {
    "build": "bun bun.config.js",
    "build:css": "bunx @tailwindcss/cli -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --minify",
    "lint": "bun run --bun prettier 'app/javascript/**/*.*' 'app/assets/stylesheets/**/*.css'",
    "lint:fix": "bun run --bun prettier --write 'app/javascript/**/*.*' 'app/assets/stylesheets/**/*.css'",
    "check-types": "bun run --bun tsc --project tsconfig.json --noEmit --preserveWatchOutput"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@tailwindcss/cli": "^4.2.1",
    "classnames": "^2.5.1",
    "daisyui": "^5.5.19",
    "lodash-es": "^4.17.23",
    "preact": "^10.28.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/lodash-es": "^4.17.12",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "printWidth": 100
  }
}