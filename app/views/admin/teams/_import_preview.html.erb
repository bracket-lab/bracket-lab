<div class="space-y-6 mb-8">
  <h2 class="text-lg font-medium mb-4">Preview Import</h2>

  <% Team::REGION_NAMES.each_with_index do |region, region_index| %>
    <div class="mb-4">
      <h3 class="text-sm font-semibold text-gray-500 uppercase mb-2"><%= region %></h3>
      <div class="bg-white shadow overflow-hidden sm:rounded-md">
        <table class="min-w-full divide-y divide-gray-200">
          <thead>
            <tr>
              <th class="px-3 py-2 text-left text-xs font-medium text-gray-500">Seed</th>
              <th class="px-3 py-2 text-left text-xs font-medium text-gray-500">Current</th>
              <th class="px-3 py-2 text-left text-xs font-medium text-gray-500">New</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @preview.select { |p| p[:team].region == region.to_s }.each do |entry| %>
              <tr class="<%= 'bg-green-50' if entry[:changed] %>">
                <td class="px-3 py-2 text-sm text-gray-500">#<%= entry[:team].seed %></td>
                <td class="px-3 py-2 text-sm <%= entry[:changed] ? 'text-gray-400 line-through' : 'text-gray-900' %>">
                  <%= entry[:team].name %>
                </td>
                <td class="px-3 py-2 text-sm <%= entry[:changed] ? 'text-green-700 font-medium' : 'text-gray-900' %>">
                  <%= entry[:new_name] %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <%= form_tag import_apply_admin_teams_path, class: "flex justify-end gap-x-3" do %>
    <% @preview.each do |entry| %>
      <%= hidden_field_tag "names[]", entry[:new_name] %>
    <% end %>
    <%= link_to "Back", import_admin_teams_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    <%= submit_tag "Apply All", class: "rounded-md bg-green-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-green-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600" %>
  <% end %>
</div>
