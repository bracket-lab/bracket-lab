<div class="bg-white shadow sm:rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h1 class="text-2xl font-bold mb-6">Import Teams</h1>

    <%= turbo_frame_tag "import_content", data: { turbo_cache: "false" } do %>
      <h2 class="text-lg font-medium mb-4">Preview Import</h2>

      <% Current.tournament.region_labels.each_with_index do |region, region_index| %>
        <div class="mb-4">
          <h3 class="text-sm font-semibold text-gray-500 uppercase mb-2"><%= region %></h3>
          <table class="min-w-full divide-y divide-gray-200">
            <thead>
              <tr>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500">Seed</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500">Current</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500">New</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% @preview.select { |p| p[:team].region == region_index }.each do |entry| %>
                <tr class="<%= 'bg-green-50' if entry[:changed] %>">
                  <td class="px-3 py-2 text-sm text-gray-500">#<%= entry[:team].seed %></td>
                  <td class="px-3 py-2 text-sm <%= entry[:changed] ? 'text-gray-400 line-through' : 'text-gray-900' %>">
                    <%= entry[:team].name %>
                  </td>
                  <td class="px-3 py-2 text-sm <%= entry[:changed] ? 'text-green-700 font-medium' : 'text-gray-900' %>">
                    <%= entry[:new_name] %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>

      <%= form_tag import_apply_admin_teams_path, class: "flex justify-end gap-x-3 mt-6", data: { turbo_frame: "_top" } do %>
        <% @preview.each do |entry| %>
          <%= hidden_field_tag "names[]", entry[:new_name] %>
        <% end %>
        <%= link_to "Edit", import_admin_teams_path(team_names: @preview.map { |e| e[:new_name] }.join("\n")), class: "btn btn-ghost" %>
        <%= submit_tag "Apply All", class: "btn btn-success" %>
      <% end %>
    <% end %>
  </div>
</div>
