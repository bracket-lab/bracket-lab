<div class="bg-white shadow sm:rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h1 class="text-2xl font-bold mb-6">Import Teams</h1>

    <%= turbo_frame_tag "import_content" do %>
      <% if @errors&.any? %>
        <div class="bg-red-50 p-4 rounded-md mb-6">
          <h2 class="text-red-700 text-sm font-medium">Import Errors</h2>
          <ul class="mt-2 text-red-600 text-sm list-disc list-inside">
            <% @errors.each do |error| %>
              <li><%= error %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_tag import_preview_admin_teams_path, class: "space-y-6" do %>
        <div>
          <label class="block text-sm font-medium leading-6 text-gray-900">
            Paste 64 team names, one per line. Order determines bracket position.
          </label>
          <div class="mt-2">
            <%= text_area_tag :team_names, @current_names,
              class: "textarea textarea-bordered w-full font-mono text-sm leading-snug",
              rows: 64 %>
          </div>
        </div>

        <div class="flex justify-end gap-x-3">
          <%= link_to "Cancel", admin_teams_path, class: "btn btn-ghost" %>
          <%= submit_tag "Preview", class: "btn btn-primary" %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
