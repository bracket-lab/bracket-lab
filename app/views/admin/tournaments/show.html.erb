<div class="bg-white shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold">Tournament Management</h1>
      <div class="flex gap-3">
        <% unless Current.tournament.set? %>
          <%= button_to "Finalize Teams",
              set_teams_admin_tournament_path,
              class: "btn btn-primary",
              data: { turbo_confirm: "Are you sure? This cannot be undone." } %>
        <% end %>
        <% if Current.tournament.not_started? %>
          <%= button_to "Start Tournament",
                        start_admin_tournament_path,
                        class: "btn btn-primary",
                        data: { turbo_confirm: "Are you sure? This cannot be undone." } %>
        <% end %>
        <%= link_to "Edit Teams", admin_teams_path, class: "btn btn-primary" %>
        <%= link_to "Edit Results", edit_admin_tournament_path, class: "btn btn-primary" %>
      </div>
    </div>

    <% unless Current.tournament.started? %>
      <div class="mb-6 p-4 bg-base-200 rounded-lg" data-controller="inline-edit">
        <div data-inline-edit-target="show" class="flex items-center gap-3">
          <h2 class="text-lg font-semibold">Region Order</h2>
          <span class="text-sm text-gray-500"><%= Current.tournament.region_labels.join(", ") %></span>
          <button type="button" data-action="inline-edit#edit" class="link link-primary text-sm">Edit</button>
        </div>

        <div data-inline-edit-target="edit" class="hidden">
          <div class="flex items-center gap-3 mb-3">
            <h2 class="text-lg font-semibold">Region Order</h2>
            <span class="text-sm text-gray-500">1=top-left, 2=bottom-left, 3=top-right, 4=bottom-right</span>
          </div>
          <div class="space-y-2">
            <% Current.tournament.region_labels.each_with_index do |label, index| %>
              <div class="flex items-center gap-3 p-2 bg-white rounded shadow-sm">
                <span class="text-sm font-mono text-gray-400 w-6"><%= index + 1 %></span>
                <span class="flex-grow font-medium"><%= label %></span>
                <div class="flex gap-1">
                  <% if index > 0 %>
                    <%= button_to update_region_labels_admin_tournament_path, method: :post, class: "btn btn-xs btn-ghost", params: { region_labels: Current.tournament.region_labels.dup.tap { |a| a[index], a[index - 1] = a[index - 1], a[index] } } do %>
                      &#9650;
                    <% end %>
                  <% else %>
                    <span class="btn btn-xs btn-ghost invisible">&#9650;</span>
                  <% end %>
                  <% if index < 3 %>
                    <%= button_to update_region_labels_admin_tournament_path, method: :post, class: "btn btn-xs btn-ghost", params: { region_labels: Current.tournament.region_labels.dup.tap { |a| a[index], a[index + 1] = a[index + 1], a[index] } } do %>
                      &#9660;
                    <% end %>
                  <% else %>
                    <span class="btn btn-xs btn-ghost invisible">&#9660;</span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
          <div class="mt-3">
            <button type="button" data-action="inline-edit#cancel" class="btn btn-ghost btn-sm">Done</button>
          </div>
        </div>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <% Current.tournament.rounds.each do |round| %>
        <div class="card bg-base-100 shadow">
          <div class="card-body">
            <h2 class="card-title"><%= round.name %></h2>
            <div class="space-y-2">
              <% Current.tournament.round_for(round.number).each do |game| %>
                <div class="p-2 bg-base-200 rounded">
                  <div class="text-sm">
                    <div><%= game.first_team&.name || "TBD" %> vs <%= game.second_team&.name || "TBD" %></div>
                    <% if game.team.present? %>
                      <div class="text-primary font-medium">Winner: <%= game.team.name %></div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
