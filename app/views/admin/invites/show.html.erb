<div class="bg-white shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold">Invite Details</h1>
      <%= link_to "Back to Invites", admin_invites_path, class: "btn btn-ghost" %>
    </div>

    <div class="space-y-4">
      <div>
        <label class="text-sm font-medium text-gray-500">Full Name</label>
        <p class="mt-1"><%= @invite.full_name %></p>
      </div>

      <div>
        <label class="text-sm font-medium text-gray-500">Email Address</label>
        <p class="mt-1"><%= @invite.email_address %></p>
      </div>

      <div>
        <label class="text-sm font-medium text-gray-500">Status</label>
        <p class="mt-1"><%= render "status", invite: @invite %></p>
      </div>

      <div>
        <label class="text-sm font-medium text-gray-500">Created By</label>
        <p class="mt-1"><%= @invite.created_by.full_name %></p>
      </div>

      <div>
        <label class="text-sm font-medium text-gray-500">Created At</label>
        <p class="mt-1"><%= @invite.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
      </div>

      <div>
        <label class="text-sm font-medium text-gray-500">Expires At</label>
        <p class="mt-1"><%= @invite.expires_at.strftime("%B %d, %Y at %I:%M %p") %></p>
      </div>

      <% if @invite.pending? %>
        <div>
          <label class="text-sm font-medium text-gray-500">Accept URL</label>
          <div class="mt-1 flex items-center gap-2">
            <input type="text"
                   value="<%= new_invite_acceptance_url(token: @invite.token) %>"
                   class="input input-bordered w-full"
                   readonly
                   id="invite-url">
            <button onclick="navigator.clipboard.writeText(document.getElementById('invite-url').value)" class="btn btn-ghost btn-sm">
              <i>content_copy</i>
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
