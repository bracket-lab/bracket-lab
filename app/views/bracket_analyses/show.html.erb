<%
  dist = @analysis.finish_distribution
  total = @analysis.total_scenarios
  sixth_plus = @analysis.sixth_plus_count
  best = @analysis.best_finish
  best_label = best == 1 ? "win" : best.ordinalize
  best_count = best ? dist[best] : 0
  best_pct = total > 0 ? (best_count.to_f / total * 100).round(1) : 0

  rank_colors = { 1 => "#fbbf24", 2 => "#9ca3af", 3 => "#cd7c2f", 4 => "#60a5fa", 5 => "#a78bfa" }
  rank_labels = { 1 => "1st", 2 => "2nd", 3 => "3rd", 4 => "4th", 5 => "5th" }
%>

<%= render layout: "layouts/page_header", locals: {
  title: "#{@bracket.name} — Analysis",
  subtitle: "#{number_with_delimiter(total)} scenarios remaining"
} do %>

  <% if @analysis.best_finish.nil? %>
    <div class="alert alert-info">
      <p>No top-5 finishes possible in any remaining scenario.</p>
    </div>
  <% else %>
    <%# Finish Distribution %>
    <div class="mb-8">
      <h2 class="text-xs uppercase tracking-wider text-base-content/50 mb-4">Finish Distribution</h2>

      <div>
          <% (1..5).each do |rank| %>
            <% count = dist[rank] %>
            <% pct = total > 0 ? (count.to_f / total * 100).round(1) : 0 %>
            <div class="flex items-center gap-2 mb-2">
              <span class="w-7 text-sm font-bold" style="color: <%= rank_colors[rank] %>"><%= rank_labels[rank] %></span>
              <div class="flex-1 bg-base-200 rounded" style="height: 1.25rem;">
                <div class="rounded opacity-80" style="height: 100%; width: <%= pct %>%; background: <%= rank_colors[rank] %>;"></div>
              </div>
              <span class="w-28 text-right text-xs text-base-content/70">
                <%= number_with_delimiter(count) %>
                <span class="text-base-content/40">(<%= pct %>%)</span>
              </span>
            </div>
          <% end %>
          <%# 6th+ row %>
          <% sixth_pct = total > 0 ? (sixth_plus.to_f / total * 100).round(1) : 0 %>
          <div class="flex items-center gap-2">
            <span class="w-7 text-sm font-bold" style="color: #4b5563">6th+</span>
            <div class="flex-1 bg-base-200 rounded" style="height: 1.25rem;">
              <div class="rounded opacity-80" style="height: 100%; width: <%= sixth_pct %>%; background: #4b5563;"></div>
            </div>
            <span class="w-28 text-right text-xs text-base-content/70">
              <%= number_with_delimiter(sixth_plus) %>
              <span class="text-base-content/40">(<%= sixth_pct %>%)</span>
            </span>
          </div>
      </div>
    </div>

    <div class="divider"></div>

    <%# Game Impact Cards %>
    <% if @analysis.game_impacts.any? %>
      <h2 class="text-xs uppercase tracking-wider text-base-content/50 mb-4">Game Impact</h2>

      <% @analysis.game_impacts.each do |impact| %>
        <%
          # Show the more advantageous outcome first
          best_count_0 = impact[:outcomes][0][best] || 0
          best_count_1 = impact[:outcomes][1][best] || 0
          ordered_outcomes = best_count_0 >= best_count_1 ? [0, 1] : [1, 0]
          first_team = ordered_outcomes.first == 0 ? impact[:team_zero] : impact[:team_one]
          second_team = ordered_outcomes.first == 0 ? impact[:team_one] : impact[:team_zero]
        %>
        <div class="bg-base-200 rounded-lg p-4 mb-3">
          <div class="mb-3">
            <span class="font-bold text-sm">
              <%= first_team.name %> vs <%= second_team.name %>
            </span>
          </div>
          <% ordered_outcomes.each_with_index do |outcome, idx| %>
            <% team = outcome == 0 ? impact[:team_zero] : impact[:team_one] %>
            <% outcome_dist = impact[:outcomes][outcome] %>
            <% outcome_total = total / 2 %>
            <% best_count_for_outcome = outcome_dist[best] || 0 %>
            <div class="<%= 'mb-3' if idx == 0 %>">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs text-base-content/70">
                  If <span class="font-bold text-base-content"><%= team.name %></span> wins
                </span>
                <span class="text-xs font-medium" style="color: <%= rank_colors[best] || '#4b5563' %>;">
                  <%= best_count_for_outcome %> / <%= number_with_delimiter(outcome_total) %> <%= best_label %>
                </span>
              </div>
              <div class="pl-2 pb-1">
                <div class="flex rounded overflow-hidden" style="height: 1rem;">
                  <% (1..5).each do |rank| %>
                    <% rc = outcome_dist[rank] || 0 %>
                    <% rpct = outcome_total > 0 ? (rc.to_f / outcome_total * 100) : 0 %>
                    <% if rpct > 0 %>
                      <div style="width: <%= rpct %>%; background: <%= rank_colors[rank] %>;"></div>
                    <% end %>
                  <% end %>
                  <% sixth_count = outcome_total - outcome_dist.values.sum %>
                  <% sixth_pct_game = outcome_total > 0 ? (sixth_count.to_f / outcome_total * 100) : 0 %>
                  <% if sixth_pct_game > 0 %>
                    <div style="width: <%= sixth_pct_game %>%; background: #4b5563;"></div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

    <% end %>
  <% end %>
<% end %>
