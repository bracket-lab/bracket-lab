<div class="card w-full max-w-sm bg-base-100 shadow-xl">
  <div class="card-body items-center text-center">
    <div class="mb-4 text-primary">
      <i class="text-6xl">sports_basketball</i>
    </div>
    <h2 class="card-title text-2xl font-bold mb-2">Welcome to <%= pool_name %></h2>
    <p class="text-base-content/60 mb-6">Create your admin account to get started.</p>

    <%= form_with(model: @user, url: setup_path, class: "w-full") do |form| %>
      <% if @user.errors.any? %>
        <div class="alert alert-error mb-4">
          <ul class="list-disc pl-5">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-control w-full">
        <label class="label">
          <span class="label-text text-left">Full Name</span>
        </label>
        <%= form.text_field :full_name,
          class: "input input-bordered w-full",
          required: true,
          autofocus: true %>
      </div>

      <div class="form-control w-full mt-4">
        <label class="label">
          <span class="label-text text-left">Email Address</span>
        </label>
        <%= form.email_field :email_address,
          class: "input input-bordered w-full",
          required: true,
          autocomplete: "username" %>
      </div>

      <div class="form-control w-full mt-4">
        <label class="label">
          <span class="label-text text-left">Password</span>
        </label>
        <%= form.password_field :password,
          class: "input input-bordered w-full",
          required: true,
          autocomplete: "new-password",
          maxlength: 72 %>
      </div>

      <div class="form-control w-full mt-4">
        <label class="label">
          <span class="label-text text-left">Confirm Password</span>
        </label>
        <%= form.password_field :password_confirmation,
          class: "input input-bordered w-full",
          required: true,
          autocomplete: "new-password",
          maxlength: 72 %>
      </div>

      <div class="form-control mt-6">
        <%= form.submit "Create Admin Account", class: "btn btn-primary w-full" %>
      </div>
    <% end %>
  </div>
</div>
