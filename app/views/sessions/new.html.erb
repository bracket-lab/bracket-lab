<div class="card w-full max-w-sm bg-base-100 shadow-xl">
  <div class="card-body items-center text-center">
    <div class="mb-4 text-primary">
      <i class="text-6xl">sports_basketball</i>
    </div>
    <h2 class="card-title text-2xl font-bold mb-2"><%= pool_name %></h2>
    <p class="text-base-content/60 mb-6">Please log in to continue</p>

    <%= form_with url: session_path, class: "w-full" do |form| %>
      <div class="form-control w-full">
        <label class="label">
          <span class="label-text text-left">Email Address</span>
        </label>
        <%= form.email_field :email_address,
          class: "input input-bordered w-full",
          required: true,
          autofocus: true,
          autocomplete: "username",
          value: params[:email_address] %>
      </div>

      <div class="form-control w-full mt-4">
        <label class="label">
          <span class="label-text text-left">Password</span>
        </label>
        <%= form.password_field :password,
          class: "input input-bordered w-full",
          required: true,
          autocomplete: "current-password",
          maxlength: 72 %>
        <label class="label">
          <div class="w-full text-right mt-4">
            <%= link_to "Forgot password?", new_password_path, class: "link link-primary text-sm" %>
          </div>
        </label>
      </div>

      <div class="form-control mt-6">
        <%= form.submit "Sign in", class: "btn btn-primary w-full" %>
      </div>
    <% end %>
  </div>
</div>
