<div class="card w-full max-w-sm bg-base-100 shadow-xl">
  <div class="card-body items-center text-center">
    <div class="mb-4 text-primary">
      <i class="text-6xl">sports_basketball</i>
    </div>
    <h2 class="card-title text-2xl font-bold mb-2">Set your password</h2>
    <p class="text-base-content/60 mb-6">
      Welcome <%= @user.full_name %>! Please set your password to complete your account setup.
    </p>

    <%= form_with url: invite_acceptances_path(token: @invite.token), class: "w-full", data: { turbo: false } do |form| %>
      <div class="form-control w-full">
        <label class="label">
          <span class="label-text text-left">Password</span>
        </label>
        <%= form.password_field "user[password]",
                                class: "input input-bordered w-full",
                                required: true,
                                maxlength: 72 %>
      </div>
      <div class="form-control w-full mt-4">
        <label class="label">
          <span class="label-text text-left">Password Confirmation</span>
        </label>
        <%= form.password_field "user[password_confirmation]",
                                class: "input input-bordered w-full",
                                required: true,
                                maxlength: 72 %>
      </div>
      <div class="form-control mt-6">
        <%= form.submit "Create Account", class: "btn btn-primary w-full" %>
      </div>
    <% end %>
  </div>
</div>