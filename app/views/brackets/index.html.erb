<%= render layout: "layouts/page_header", locals: { 
  title: "Brackets",
  actions: capture do %>
      <% if @brackets.any? %>
        <%= link_to "Create New Bracket", new_bracket_path, class: "btn btn-primary" %>
      <% end %>
  <% end 
} do %>

    <% if @brackets.empty? %>
      <div class="text-center py-12">
        <h3 class="text-lg font-medium text-gray-900 mb-2">No brackets yet</h3>
        <p class="text-gray-500 mb-6">Create your first bracket to join the pool!</p>
        <%= link_to new_bracket_path, class: "btn btn-primary" do %>
          <i class="mr-2">add</i>
          Create Your First Bracket
        <% end %>
      </div>
    <% else %>
    <div class="space-y-4">
      <% @brackets.each do |bracket| %>
        <%= link_to bracket_path(bracket), class: "block p-4 hover:bg-base-100 rounded-lg" do %>
          <div class="flex justify-between items-center">
            <div>
              <h3 class="text-lg font-medium">
                <%= bracket.name %>
                  <% if bracket.paid? %>
                    <div class="badge badge-success badge-sm">paid</div>
                  <% else %>
                    <div class="badge badge-warning badge-sm">unpaid</div>
                  <% end %>
              </h3>

              <div class="text-sm text-gray-500 mt-1">
                <% bracket.final_four_teams.each do |team| %>
                  <span class="<%= team.eliminated? ? 'line-through' : '' %>">
                    <%= team.name %>
                  </span><%= ',' unless team == bracket.final_four_teams.last %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
    <% end %>

<% end %>
