<%= render layout: "layouts/page_header", locals: {
  title: @bracket.name,
  actions: capture do %>
  <% if Current.tournament.display_eliminations? %>
    <%= link_to "Analysis", bracket_analysis_path(@bracket), class: "btn btn-outline" %>
  <% end %>
  <% if policy(@bracket).destroy? %>
    <%= button_to bracket_path(@bracket),
                  method: :delete,
                  class: "btn btn-error",
                  data: {
                    turbo_confirm: "Are you sure you want to delete this bracket?"
                  } do %>
      Delete
    <% end %>
  <% end %>
  <% if policy(@bracket).edit? %>
    <%= link_to "Edit", edit_bracket_path(@bracket), class: "btn btn-primary" %>
  <% end %>
<% end
   } do %>
  <%= render "application/tournament", bracket: @bracket %>
<% end %>
