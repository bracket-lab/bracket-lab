<div class="card w-full max-w-sm bg-base-100 shadow-xl">
  <div class="card-body items-center text-center">
    <div class="mb-4 text-primary">
      <i class="text-6xl">sports_basketball</i>
    </div>
    <h2 class="card-title text-2xl font-bold mb-2">Reset Password</h2>
    <p class="text-base-content/60 mb-6">Please enter your new password below.</p>

    <%= form_with url: password_path(params[:token]), method: :put, class: "w-full" do |form| %>
      <div class="form-control w-full">
        <label class="label">
          <span class="label-text text-left">New Password</span>
        </label>
        <%= form.password_field :password,
          class: "input input-bordered w-full",
          required: true,
          autofocus: true,
          autocomplete: "new-password",
          maxlength: 72 %>
      </div>
      
      <div class="form-control w-full mt-4">
        <label class="label">
          <span class="label-text text-left">Confirm New Password</span>
        </label>
        <%= form.password_field :password_confirmation,
          class: "input input-bordered w-full",
          required: true,
          autocomplete: "new-password",
          maxlength: 72 %>
      </div>
      
      <div class="form-control mt-6">
        <%= form.submit "Update Password", class: "btn btn-primary w-full" %>
      </div>

      <div class="text-center mt-4">
        <%= link_to "Back to sign in", new_session_path, class: "link link-primary text-sm" %>
      </div>
    <% end %>
  </div>
</div>
