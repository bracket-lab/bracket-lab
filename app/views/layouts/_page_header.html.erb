<div class="md:px-4 py-5">
    <div class="flex justify-between items-center mb-6">
      <div>
        <h1 class="text-2xl font-bold truncate"><%= title %></h1>
        <% if local_assigns[:subtitle] %>
          <p class="text-sm text-base-content/60"><%= subtitle %></p>
        <% end %>
      </div>
      <div class="flex gap-3">
        <% if local_assigns[:actions] %>
          <%= actions %>
        <% end %>
      </div>
    </div>
    <%= yield %>
  </div>
