<div class="container mx-auto px-4 py-8">
  <div class="mx-auto">
    <h1 class="text-2xl font-bold mb-6">Possible Outcomes</h1>
    <p class="mb-4">There are <%= @outcomes.length %> possible outcomes remaining.</p>
  </div>

  <div class="grid grid-cols-1 gap-8">
    <% @outcomes.each do |outcome| %>
      <div class="bg-base-100 rounded-box shadow-md p-6">
        <h2 class="text-xl font-bold mb-4"><%= outcome[:winner].name %> beats <%= outcome[:loser].name %></h2>

        <ul class="list bg-base-100">
          <% outcome[:ranked_brackets].each do |ranked|
            bracket = ranked[:bracket]
            rank = ranked[:rank]
            tied = ranked[:tied]
            points = ranked[:points]
          %>
            <li class="list-row px-0 md:px-5">
              <div class="font-thin w-7">
                <% if tied %>
                  <div class="text-sm">tied</div>
                <% end %>
                <div class="text-xl"><%= rank %></div>
              </div>

              <div class="list-col-grow">
                <%= link_to bracket_path(bracket) do %>
                  <div class="font-bold sm:truncate sm:max-w-sm">
                    <%= bracket.name.titleize %>
                  </div>
                  <div class="text-xs uppercase font-semibold opacity-60"><%= bracket.user.full_name %></div>
                <% end %>
              </div>

              <div class="text-right text-xl">
                <%= points %>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>
</div>